{
  "info": {
    "name": "Train Booking API - Dev Environment",
    "description": "Postman Collection for the Train Booking System. \n\n**Note**: Make sure your local Rails server is running on `http://localhost:3000/`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"user\": {\n        \"email\": \"new_postman_user@example.com\",\n        \"password\": \"password123\",\n        \"password_confirmation\": \"password123\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": [
                "http://localhost:3000"
              ],
              "port": "3000",
              "path": [
                "users"
              ]
            },
            "description": "Registers a new user in the system. The response body will contain your `token` representing your JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    let res = pm.response.json();",
                  "    pm.collectionVariables.set(\"jwt_token\", res.token);",
                  "    console.log(\"Saved JWT token from registration!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"user\": {\n        \"email\": \"user@example.com\",\n        \"password\": \"password123\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/users/sign_in",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "users",
                "sign_in"
              ]
            },
            "description": "Logs in the seeded dummy user. Grab the `token` from the JSON response or the `Authorization` header to use in future requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let res = pm.response.json();",
                  "    pm.collectionVariables.set(\"jwt_token\", res.token);",
                  "    console.log(\"Automatically saved JWT token!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. User Logout",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/users/sign_out",
              "protocol": "http",
              "host": [
                "http://localhost:3000"
              ],
              "port": "3000",
              "path": [
                "users",
                "sign_out"
              ]
            },
            "description": "Logs out the user currently identified by the {{jwt_token}} variable."
          }
        },
